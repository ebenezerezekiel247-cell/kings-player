{
  "buildCommand": "pnpm install && pnpm --filter @workspace/kings-player run build",
  "outputDirectory": "public",
  "installCommand": "pnpm install",
  "framework": null,
  "routes": [
    { "src": "/api/ping", "dest": "/api/ping" },
    { "src": "/api/(.*)", "dest": "/api/[...path]" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
