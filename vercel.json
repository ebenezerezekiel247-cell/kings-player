{
  "buildCommand": "pnpm install && pnpm --filter @workspace/kings-player run build",
  "outputDirectory": "public",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
