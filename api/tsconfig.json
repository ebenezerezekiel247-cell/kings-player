{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "allowJs": true
  },
  "include": ["./**/*.ts", "../artifacts/api-server/src/**/*.ts", "../lib/**/*.ts"]
}
